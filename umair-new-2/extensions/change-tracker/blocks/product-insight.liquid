{% if product %}
  {% assign selected_variant = product.selected_or_first_available_variant %}

  <div id="ct-price-change-{{ block.id }}"
       class="ct-price-change"
      style="display:none;"
      data-ct-product-id="{{ product.id }}"
      data-ct-handle="{{ product.handle | escape }}"
      data-ct-initial-variant-id="{{ selected_variant.id }}"
       {{ block.shopify_attributes }}>

    {% comment %} <p class="ct-price-change-title">Price Updated</p> {% endcomment %}

    <p class="ct-price-change-text">
      Old Price: <span data-ct-old></span>
      {% comment %} <span data-ct-current></span> {% endcomment %}
    </p>
{% comment %} 
    <p class="ct-price-change-text">
      Current Price: <span data-ct-current>{{ selected_variant.price | money }}</span>
    </p> {% endcomment %}

  </div>

  <style>
    #ct-price-change-{{ block.id }} {
      /* border: 1px solid #86efac;
      background: #f0fdf4;
      border-radius: 10px;
      padding: 12px;
      margin-top: 12px; */
    }
    #ct-price-change-{{ block.id }} .ct-price-change-title {
      margin: 0 0 6px;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      color: #166534;
    }
    #ct-price-change-{{ block.id }} .ct-price-change-text {
      margin: 4px 0;
      font-size: 16px;
      color: #333333;
      font-weight: 700;
    }
    #ct-price-change-{{ block.id }} [data-ct-old] {
      text-decoration: line-through;
      color: #991b1b;
      font-weight: 700;
      margin-left: 5px;
    }
    #ct-price-change-{{ block.id }} [data-ct-current] {
      font-weight: 700;
      margin-left: 5px;
    }
  </style>

  <script>
    (() => {
      const root = document.getElementById('ct-price-change-{{ block.id }}');
      if (!root) return;

      const toVariantId = (value) => {
        if (value === null || value === undefined) return '';
        const raw = String(value).trim();
        if (!raw) return '';

        const gidMatch = raw.match(/ProductVariant\/(\d+)/i);
        if (gidMatch) return gidMatch[1];

        const onlyDigits = raw.match(/^\d+$/);
        if (onlyDigits) return onlyDigits[0];

        const trailingDigits = raw.match(/(\d{6,})$/);
        return trailingDigits ? trailingDigits[1] : '';
      };

      const fmt = (amount) => {
        const numeric = Number(amount);
        if (!Number.isFinite(numeric)) return '';

        if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
          return window.Shopify.formatMoney(Math.round(numeric * 100));
        }

        return '$' + numeric.toFixed(2);
      };

      const oldEl = root.querySelector('[data-ct-old]');
      const currentEl = root.querySelector('[data-ct-current]');
      let activeVariantId = toVariantId(root.dataset.ctInitialVariantId || '');
      const productVariants = {{ product.variants | json }};

      const hide = () => {
        if (oldEl) oldEl.textContent = '';
        if (currentEl) currentEl.textContent = '';
        root.style.display = 'none';
      };

      const show = (oldPrice, newPrice) => {
        if (oldEl) oldEl.textContent = fmt(oldPrice);
        if (currentEl) currentEl.textContent = ' -> ' + fmt(newPrice);
        root.style.display = 'block';
      };

      const getVariantFallbackPrice = (variantIdCandidate) => {
        if (!Array.isArray(productVariants) || productVariants.length === 0) return null;

        const wantedId = toVariantId(variantIdCandidate || getSelectedVariantId());
        if (!wantedId) return null;

        const match = productVariants.find((variant) => toVariantId(variant?.id) === wantedId);
        if (!match) return null;

        const compareAtCents = Number(match.compare_at_price);
        const priceCents = Number(match.price);

        if (!Number.isFinite(compareAtCents) || !Number.isFinite(priceCents)) return null;
        if (compareAtCents <= priceCents) return null;

        return {
          oldPrice: compareAtCents / 100,
          newPrice: priceCents / 100,
        };
      };

      const findCandidateForms = () => {
        const scoped = root.closest('.shopify-section, section, main, .product, .product__info-wrapper');
        const scopedForms = scoped ? Array.from(scoped.querySelectorAll('form[action*="/cart/add"]')) : [];
        if (scopedForms.length) return scopedForms;
        return Array.from(document.querySelectorAll('form[action*="/cart/add"]'));
      };

      const findVariantIdInForms = () => {
        const forms = findCandidateForms();

        for (const form of forms) {
          const idInput = form.querySelector('input[name="id"], select[name="id"]');
          const inputVariant = toVariantId(idInput && 'value' in idInput ? idInput.value : '');
          if (inputVariant) return inputVariant;

          const checkedWithData = form.querySelector('[name^="options"]:checked[data-variant-id], [data-variant-id][aria-checked="true"]');
          const dataVariant = toVariantId(checkedWithData ? checkedWithData.getAttribute('data-variant-id') : '');
          if (dataVariant) return dataVariant;
        }

        return '';
      };

      const getSelectedVariantId = () => {
        const queryVariant = toVariantId(new URLSearchParams(window.location.search).get('variant'));
        if (queryVariant) return queryVariant;

        const formVariant = findVariantIdInForms();
        if (formVariant) return formVariant;

        const analyticsVariant = toVariantId(window.ShopifyAnalytics?.meta?.selectedVariantId || '');
        if (analyticsVariant) return analyticsVariant;

        return activeVariantId || toVariantId(root.dataset.ctInitialVariantId || '');
      };

      let lastRequestId = 0;
      const fetchPriceChange = (incomingVariantId) => {
        const requestId = ++lastRequestId;

        const params = new URLSearchParams({
          product_id: root.dataset.ctProductId || '{{ product.id }}',
          handle: root.dataset.ctHandle || '{{ product.handle | url_encode }}',
        });

        const variantId = toVariantId(incomingVariantId) || getSelectedVariantId();
        if (variantId) activeVariantId = String(variantId);
        if (variantId) params.set('variant_id', variantId);
        params.set('_', String(Date.now()));

        fetch('/apps/tracker/price-change?' + params.toString(), {
          method: 'GET',
          credentials: 'same-origin',
          headers: { 'Accept': 'application/json' },
          cache: 'no-store',
        })
          .then((r) => r.ok ? r.json() : Promise.reject())
          .then((data) => {
            if (requestId !== lastRequestId) return;

            if (!data || !data.hasChange) {
              const fallback = getVariantFallbackPrice(variantId);
              if (fallback) {
                show(fallback.oldPrice, fallback.newPrice);
              } else {
                hide();
              }
              return;
            }

            const oldPrice = Number(data.oldPrice);
            const newPrice = Number(data.newPrice);

            if (Number.isFinite(oldPrice) && Number.isFinite(newPrice)) {
              show(oldPrice, newPrice);
              return;
            }

            const fallback = getVariantFallbackPrice(variantId);
            if (fallback) {
              show(fallback.oldPrice, fallback.newPrice);
            } else {
              hide();
            }
          })
          .catch(() => {
            if (requestId === lastRequestId) hide();
          });
      };

      let scheduledRefresh = 0;
      const scheduleFetchPriceChange = (variantId, delay = 30) => {
        window.clearTimeout(scheduledRefresh);
        scheduledRefresh = window.setTimeout(() => {
          fetchPriceChange(variantId || '');
        }, delay);
      };

      fetchPriceChange();

      document.addEventListener('variant:change', (event) => {
        const maybeVariantId = event?.detail?.variant?.id || event?.detail?.id || event?.detail?.variantId || '';
        scheduleFetchPriceChange(maybeVariantId ? String(maybeVariantId) : '');
      });
      document.addEventListener('variant:changed', (event) => {
        const maybeVariantId = event?.detail?.variant?.id || event?.detail?.id || event?.detail?.variantId || '';
        scheduleFetchPriceChange(maybeVariantId ? String(maybeVariantId) : '');
      });
      document.addEventListener('product:variant-change', (event) => {
        const maybeVariantId = event?.detail?.variant?.id || event?.detail?.id || event?.detail?.variantId || '';
        scheduleFetchPriceChange(maybeVariantId ? String(maybeVariantId) : '');
      });
      document.addEventListener('change', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target.matches('input[name="id"], select[name="id"], [name^="options"], [data-variant-id]')) {
          scheduleFetchPriceChange(target.getAttribute('data-variant-id') || target.value || '');
        }
      });
      document.addEventListener('input', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target.matches('input[name="id"], select[name="id"], [name^="options"], [data-variant-id]')) {
          scheduleFetchPriceChange(target.getAttribute('data-variant-id') || target.value || '');
        }
      });
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest('form[action*="/cart/add"] [name^="options"], form[action*="/cart/add"] .product-form__input')) {
          scheduleFetchPriceChange('', 90);
        }
      });
      document.addEventListener('shopify:section:load', () => scheduleFetchPriceChange('', 60));

      const patchHistory = (methodName) => {
        const original = history[methodName];
        if (typeof original !== 'function') return;

        history[methodName] = function (...args) {
          const result = original.apply(this, args);
          scheduleFetchPriceChange('', 10);
          return result;
        };
      };

      patchHistory('pushState');
      patchHistory('replaceState');

      if (typeof MutationObserver !== 'undefined') {
        const variantSelector = 'input[name="id"], select[name="id"], [data-variant-id], [name^="options"]';
        const nodeHasVariantControls = (node) => {
          if (!(node instanceof Element)) return false;
          if (node.matches(variantSelector)) return true;
          return Boolean(node.querySelector(variantSelector));
        };

        const observer = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            const target = mutation.target;
            if (!(target instanceof HTMLElement)) continue;

            if (target.matches(variantSelector)) {
              const value = target.getAttribute('data-variant-id') || target.getAttribute('value') || target.value || '';
              scheduleFetchPriceChange(value, 20);
              return;
            }

            if (mutation.type === 'childList') {
              for (const node of mutation.addedNodes) {
                if (nodeHasVariantControls(node)) {
                  scheduleFetchPriceChange('', 40);
                  return;
                }
              }

              for (const node of mutation.removedNodes) {
                if (nodeHasVariantControls(node)) {
                  scheduleFetchPriceChange('', 40);
                  return;
                }
              }
            }
          }
        });

        observer.observe(document.body, {
          attributes: true,
          attributeFilter: ['value', 'data-variant-id', 'checked', 'selected'],
          childList: true,
          subtree: true,
        });
      }

      window.addEventListener('popstate', () => scheduleFetchPriceChange('', 20));
    })();
  </script>

{% endif %}

{% schema %}
{
  "name": "Product Change Insight",
  "target": "section",
  "settings": []
}
{% endschema %} 